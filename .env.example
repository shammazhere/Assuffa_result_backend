# Server Configuration
PORT=5000
NODE_ENV=production

# Database (Supabase / PostgreSQL)
# For Vercel, use the Session pooling URL (port 5432) or Transaction mode (port 6543)
DATABASE_URL="postgresql://username:password@db.id.supabase.co:5432/postgres?schema=public"

# Security
# Generate a strong 32+ character string for JWT_SECRET
JWT_SECRET="generate-a-long-random-string-for-production"

# CORS
# The URL of your deployed frontend (required in production)
FRONTEND_URL="https://your-app.vercel.app"
